{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "tsProgram": "tsconfig.json"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "src/index.ts"
    },
    {
      "source": "/health",
      "destination": "src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "src/index.ts"
    }
  ]
}
