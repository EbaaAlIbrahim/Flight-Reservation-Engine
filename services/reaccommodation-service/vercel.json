{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "tsProgram": "tsconfig.json",
        "includeFiles": [
          "src/config/**",
          "src/controllers/**",
          "src/routes/**",
          "src/db/**"
        ]
  }
}
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "src/index.ts"
    }
  ]
}
