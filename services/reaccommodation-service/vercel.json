{
  "version": 2,
  "builds": [
    {
      "src": "services/reaccommodation-service/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "services/reaccommodation-service/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "services/reaccommodation-service/src/index.ts"
    }
  ]
}
